# === Keystatic (modo GitHub) ===
# Se obtienen al crear la GitHub App (ver docs/keystatic-configuracion.md).
# Copiá este archivo como ".env" y completá los valores. NO subir ".env" al repo.

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Cadena secreta larga y aleatoria (p. ej. `openssl rand -hex 32`).
KEYSTATIC_SECRET=

# Slug (nombre) de la GitHub App, visible en su URL de instalación.
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Opcional: token para leer el contenido desde GitHub en el build.
# KEYSTATIC_GITHUB_TOKEN=
