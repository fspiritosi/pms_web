---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, path } from '@/i18n/ui';

// 404 en español (idioma por defecto). El sitio es estático.
const locale = 'es' as const;
const t = useTranslations(locale);
---

<BaseLayout
  title={`${t.notFound.title} · PMS`}
  description={t.notFound.text}
  locale={locale}
  esPath="/"
  enPath="/en/"
  noindex
>
  <section class="container-pms flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-display text-6xl font-semibold text-brand">404</p>
    <h1 class="mt-4 text-3xl">{t.notFound.title}</h1>
    <p class="mt-3 max-w-md text-ink-soft">{t.notFound.text}</p>
    <a href={path('home', locale)} class="mt-8 rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-600">
      {t.notFound.cta}
    </a>
  </section>
</BaseLayout>
