---
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n/ui';
import type { Locale } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  /** Path de esta misma página en cada idioma (para hreflang y el toggle). */
  esPath: string;
  enPath: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, locale, esPath, enPath, ogImage, noindex, jsonLd } = Astro.props;
const t = useTranslations(locale);
---

<!doctype html>
<html lang={t.meta.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logos/pms-dark.png" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      locale={locale}
      esPath={esPath}
      enPath={enPath}
      ogImage={ogImage}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-brand focus:px-4 focus:py-2 focus:text-white">
      {locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>
    <Header locale={locale} esPath={esPath} enPath={enPath} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
