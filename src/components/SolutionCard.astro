---
import { useTranslations } from '@/i18n/ui';
import type { Locale } from '@/lib/site';

interface Props {
  locale: Locale;
  title: string;
  tagline: string;
  summary: string;
  href: string;
  available?: boolean;
}
const { locale, title, tagline, summary, href, available = true } = Astro.props;
const t = useTranslations(locale);
---

<article class="group relative flex flex-col rounded-xl border border-line bg-white p-7 transition-all hover:border-brand hover:shadow-lg">
  <div class="flex items-center gap-2">
    <h3 class="text-xl">{title}</h3>
    {
      !available && (
        <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold text-brand">
          {t.solutions.comingSoon}
        </span>
      )
    }
  </div>
  <p class="mt-1 text-sm font-medium text-brand">{tagline}</p>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{summary}</p>
  {
    available && (
      <a href={href} class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-brand">
        {t.solutions.learnMore}
        <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </a>
    )
  }
</article>
