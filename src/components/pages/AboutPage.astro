---
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { useTranslations, path } from '@/i18n/ui';
import type { Locale } from '@/lib/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Section>
  <SectionHeading kicker={t.nav.company} title={t.about.title} subtitle={t.about.subtitle} />
  <div class="mt-8 max-w-3xl">
    <p class="text-lg leading-relaxed text-ink-soft">{t.about.body}</p>
  </div>

  <div class="mt-14">
    <h2 class="text-2xl">{t.about.valuesTitle}</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.home.why.map((item) => (
          <div class="rounded-xl border border-line bg-white p-6">
            <h3 class="text-lg">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="mt-16 rounded-2xl bg-surface-soft p-8 md:flex md:items-center md:justify-between">
    <div>
      <h2 class="text-2xl">{t.home.ctaBannerTitle}</h2>
      <p class="mt-2 text-ink-soft">{t.home.ctaBannerText}</p>
    </div>
    <a href={path('contact', locale)} class="mt-5 inline-block rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-600 md:mt-0">
      {t.home.ctaBannerButton}
    </a>
  </div>
</Section>
