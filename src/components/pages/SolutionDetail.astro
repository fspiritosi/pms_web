---
import Section from '@/components/Section.astro';
import { render, type CollectionEntry } from 'astro:content';
import { useTranslations, path } from '@/i18n/ui';
import type { Locale } from '@/lib/site';

interface Props {
  locale: Locale;
  entry: CollectionEntry<'soluciones'>;
}
const { locale, entry } = Astro.props;
const t = useTranslations(locale);
const { Content } = await render(entry);
const d = entry.data;
---

<Section>
  <a href={path('solutions', locale)} class="inline-flex items-center gap-1.5 text-sm font-medium text-muted hover:text-brand">
    <span aria-hidden="true">←</span>
    {t.solutions.backToSolutions}
  </a>

  <div class="mt-6 max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-wider text-brand">{d.tagline}</p>
    <h1 class="mt-3 text-4xl md:text-5xl">{d.title}</h1>
    <p class="mt-5 text-lg text-ink-soft">{d.summary}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={path('contact', locale)} class="rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-600">
        {t.home.heroCtaSecondary}
      </a>
      {
        d.ctaHref && d.ctaLabel && (
          <a href={d.ctaHref} class="rounded-lg border border-line px-6 py-3 text-sm font-semibold text-ink transition-colors hover:border-brand hover:text-brand">
            {d.ctaLabel}
          </a>
        )
      }
    </div>
  </div>

  {
    d.features.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl">{t.solutions.featuresTitle}</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {d.features.map((feat) => (
            <div class="rounded-xl border border-line bg-white p-6">
              <h3 class="text-lg">{feat.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{feat.description}</p>
            </div>
          ))}
        </div>
      </div>
    )
  }

  <div class="prose-pms mt-16 max-w-3xl">
    <Content />
  </div>
</Section>
