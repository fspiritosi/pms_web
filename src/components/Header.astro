---
import { site, type Locale } from '@/lib/site';
import { useTranslations, path, otherLocale } from '@/i18n/ui';

interface Props {
  locale: Locale;
  esPath: string;
  enPath: string;
}

const { locale, esPath, enPath } = Astro.props;
const t = useTranslations(locale);
const other = otherLocale(locale);
const otherPath = other === 'es' ? esPath : enPath;

const links = [
  { label: t.nav.home, href: path('home', locale) },
  { label: t.nav.solutions, href: path('solutions', locale) },
];
const companyLinks = [
  { label: t.nav.about, href: path('about', locale) },
  { label: t.nav.blog, href: path('blog', locale) },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => current === href.replace(/\/$/, '');
---

<header class="sticky top-0 z-50 border-b border-line bg-white/90 backdrop-blur">
  <nav class="container-pms flex h-16 items-center justify-between gap-4" aria-label="Principal">
    <!-- Logo -->
    <a href={path('home', locale)} class="flex items-center" aria-label={site.name}>
      <img src="/logos/pms-dark.png" alt={site.shortName} width="120" height="48" class="h-8 w-auto" />
    </a>

    <!-- Nav desktop -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-brand',
                isActive(l.href) ? 'text-brand' : 'text-ink-soft',
              ]}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))
      }
      <!-- Dropdown Empresa -->
      <li class="group relative">
        <button
          class="flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium text-ink-soft transition-colors hover:text-brand"
          aria-haspopup="true"
        >
          {t.nav.company}
          <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div
          class="invisible absolute left-0 top-full min-w-44 translate-y-1 rounded-xl border border-line bg-white p-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
        >
          {
            companyLinks.map((l) => (
              <a href={l.href} class="block rounded-lg px-3 py-2 text-sm text-ink-soft transition-colors hover:bg-surface-soft hover:text-brand">
                {l.label}
              </a>
            ))
          }
        </div>
      </li>
      <li>
        <a
          href={path('contact', locale)}
          class:list={[
            'rounded-md px-3 py-2 text-sm font-medium transition-colors hover:text-brand',
            isActive(path('contact', locale)) ? 'text-brand' : 'text-ink-soft',
          ]}
        >
          {t.nav.contact}
        </a>
      </li>
    </ul>

    <!-- Acciones -->
    <div class="flex items-center gap-2">
      <a
        href={otherPath}
        class="hidden rounded-md border border-line px-2.5 py-1.5 text-xs font-semibold uppercase text-ink-soft transition-colors hover:border-brand hover:text-brand sm:inline-block"
        hreflang={other}
        aria-label={`Cambiar idioma a ${other.toUpperCase()}`}
      >
        {other}
      </a>
      <a
        href={site.loginUrl}
        class="hidden rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-600 md:inline-block"
      >
        {t.nav.login}
      </a>

      <!-- Toggle mobile -->
      <button
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-ink md:hidden"
        aria-label={t.nav.openMenu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="hidden border-t border-line bg-white md:hidden">
    <ul class="container-pms flex flex-col gap-1 py-4">
      {
        [...links, ...companyLinks, { label: t.nav.contact, href: path('contact', locale) }].map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 text-base font-medium text-ink-soft hover:bg-surface-soft hover:text-brand">
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 flex items-center gap-2">
        <a href={otherPath} hreflang={other} class="flex-1 rounded-lg border border-line px-3 py-2.5 text-center text-sm font-semibold uppercase text-ink-soft">
          {other}
        </a>
        <a href={site.loginUrl} class="flex-1 rounded-lg bg-brand px-3 py-2.5 text-center text-sm font-semibold text-white">
          {t.nav.login}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
